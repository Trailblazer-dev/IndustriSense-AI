#!/usr/bin/env python3
"""
IndustriSense AI - Web App Environment Configuration
Place this .env.example file in web_app/ directory and rename to .env
"""

# ===== Flask Configuration =====
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-flask-secret-key-change-in-production

# ===== PayHero Configuration =====
# Get these from https://payhero.io/dashboard/settings/api-keys
PAYHERO_USERNAME=REPLACE_WITH_YOUR_PAYHERO_USERNAME
# Basic_Auth_Token=REPLACE_WITH_BASE64_BASIC_TOKEN
# PAYHERO_API_PASSWORD=REPLACE_WITH_PAYHERO_API_PASSWORD
# PAYHERO_CHANNEL_ID=REPLACE_WITH_CHANNEL_ID

# Sandbox Mode (set to false for production)
PAYHERO_SANDBOX=true

# ===== Payment URL Configuration =====
# These URLs are where PayHero redirects after payment
PAYMENT_SUCCESS_URL=http://localhost:5000/payment/success
PAYMENT_FAIL_URL=http://localhost:5000/payment/failure

# For production, update to:
# PAYMENT_SUCCESS_URL=https://yourdomain.com/payment/success
# PAYMENT_FAIL_URL=https://yourdomain.com/payment/failure

# ===== Application Configuration =====
DEBUG=False

# ===== Database Configuration (Future) =====
# DATABASE_URL=sqlite:///industrisense.db

# ===== Email Configuration (Future) =====
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_USE_TLS=True
