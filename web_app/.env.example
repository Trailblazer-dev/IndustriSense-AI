#!/usr/bin/env python3
"""
IndustriSense AI - Web App Environment Configuration
Place this .env file in web_app/ directory
"""

# ===== Flask Configuration =====
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-flask-secret-key-cFLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=REPLACE_WITH_SECURE_SECRET_KEY

# ===== PayHero Configuration =====
# Get these from https://payhero.io/dashboard/settings/api-keys
PAYHERO_USERNAME=your_payhero_username
Basic_Auth_Token=fill_in_basic_auth_token_from_payhero_dashboard
PAYHERO_API_PASSWORD=fill_in_api_password_from_payhero_dashboard
PAYHERO_CHANNEL_ID=fill_in_channel_id_from_payhero_dashboard

# Sandbox Mode (set to false for production)
PAYHERO_SANDBOX=true

# ===== Payment URL Configuration =====
# These URLs are where PayHero redirects after payment
PAYMENT_SUCCESS_URL=http://localhost:5000/payment/success
PAYMENT_FAIL_URL=http://localhost:5000/payment/failure

# For production, update to:
# PAYMENT_SUCCESS_URL=https://yourdomain.com/payment/success
# PAYMENT_FAIL_URL=https://yourdomain.com/payment/failure

# ===== Application Configuration =====
DEBUG=False
MAX_TOOL_WEAR=254
ALLOWED_ORIGINS=http://localhost:5000
# ===== Database Configuration (Future) =====
# DATABASE_URL=sqlite:///industrisense.db

# ===== Email Configuration (Future) =====
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_USE_TLS=True

# Sandbox Mode (set to false for production)
PAYHERO_SANDBOX=true

# ===== Payment URL Configuration =====
# These URLs are where PayHero redirects after payment
PAYMENT_SUCCESS_URL=http://localhost:5000/payment/success
PAYMENT_FAIL_URL=http://localhost:5000/payment/failure

# For production, update to:
# PAYMENT_SUCCESS_URL=https://yourdomain.com/payment/success
# PAYMENT_FAIL_URL=https://yourdomain.com/payment/failure

# ===== Application Configuration =====
DEBUG=False
MAX_TOOL_WEAR=254
ALLOWED_ORIGINS=http://localhost:5000
