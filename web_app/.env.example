#!/usr/bin/env python3
"""
IndustriSense AI - Web App Environment Configuration
Place this .env file in web_app/ directory
"""

# ===== Flask Configuration =====
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-flask-secret-key-change-in-production

# ===== PayHero Configuration =====
# Get these from https://payhero.io/dashboard/settings/api-keys
PAYHERO_API_KEY=your_payhero_api_key
PAYHERO_API_SECRET=your_payhero_api_secret

# Sandbox Mode (set to false for production)
PAYHERO_SANDBOX=true

# ===== Payment URL Configuration =====
# These URLs are where PayHero redirects after payment
PAYMENT_SUCCESS_URL=http://localhost:5000/payment/success
PAYMENT_FAIL_URL=http://localhost:5000/payment/failure

# For production, update to:
# PAYMENT_SUCCESS_URL=https://yourdomain.com/payment/success
# PAYMENT_FAIL_URL=https://yourdomain.com/payment/failure

# ===== Application Configuration =====
DEBUG=False
MAX_TOOL_WEAR=254
ALLOWED_ORIGINS=http://localhost:5000
